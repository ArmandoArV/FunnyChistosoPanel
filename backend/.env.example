# Database Configuration
DB_HOST=c2panel-postgres.postgres.database.azure.com
DB_PORT=5432
DB_USER=c2admin
DB_PASSWORD=your_password_here
DB_NAME=c2panel

# Server Ports
C2_PORT=:4444
API_PORT=:8080

# Discord Integration
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Screenshot Storage
SCREENSHOT_STORAGE_PATH=./screenshots
SCREENSHOT_BASE_URL=https://your-cloudflare-tunnel-url.trycloudflare.com/screenshots

# Optional: JWT Secret for API authentication
JWT_SECRET=change_this_to_random_string
